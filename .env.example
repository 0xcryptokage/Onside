# TxLINE (World Cup free tier — get your own token following the README)
TXLINE_HOST=https://txline-dev.txodds.com
TXLINE_API_TOKEN=your_txline_api_token_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_channel_id_here
# The linked discussion group's chat ID (for reading prediction replies —
# see README for how to set up a linked discussion group and find this ID)
TELEGRAM_DISCUSSION_GROUP_ID=your_discussion_group_id_here

# Twitter/X — leave blank until you've set these up; bot works fine without them
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
# Read-only Bearer Token (app-only auth) — needed to search/read replies,
# separate from the OAuth1 keys above which are used for posting
TWITTER_BEARER_TOKEN=
# Your bot's own X username (no @), used to identify its own posts
TWITTER_BOT_USERNAME=Onsidelive_bot
